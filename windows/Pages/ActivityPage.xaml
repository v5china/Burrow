<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:BurrowWin.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource BurrowBackgroundGreenBrush}"
    Loaded="ActivityPage_Loaded"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Activity" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontFamily="{StaticResource BurrowMonoFont}"
                FontSize="18"
                FontWeight="Bold"
                Foreground="{StaticResource BurrowDimBrush}"
                Text="{Binding Summary}" />
            <Button
                Grid.Column="2"
                Command="{Binding RefreshCommand}"
                Style="{StaticResource BurrowIconButtonStyle}">
                <FontIcon Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource BurrowCardBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    FontFamily="{StaticResource BurrowMonoFont}"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding HistoryPath}"
                    TextWrapping="Wrap" />
                <ListView Grid.Row="1" ItemsSource="{Binding Entries}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OperationHistoryEntry">
                            <Grid MinHeight="70" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Fill="{StaticResource BurrowGreenBrush}" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    Foreground="{StaticResource BurrowMutedBrush}"
                                    Text="{x:Bind TimestampText}" />
                                <TextBlock
                                    Grid.Column="2"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Operation}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="3"
                                    Foreground="{StaticResource BurrowGoldBrush}"
                                    Text="{x:Bind ResultText}" />
                                <TextBlock
                                    Grid.Column="4"
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    Foreground="{StaticResource BurrowDimBrush}"
                                    Text="{x:Bind Summary}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
