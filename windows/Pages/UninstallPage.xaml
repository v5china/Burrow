<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Pages.UninstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:BurrowWin.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BurrowWin.ViewModels"
    x:Name="AppsRoot"
    Background="{StaticResource BurrowBackgroundBrownBrush}"
    mc:Ignorable="d"
    Loaded="UninstallPage_Loaded">

    <Page.Resources>
        <Style x:Key="AppsListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="AppsSearchBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="320" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="#14100E" />
            <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BurrowStrokeBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="AppsSmallPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="#463124" />
        </Style>
    </Page.Resources>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
        </Grid.RowDefinitions>

        <Grid Padding="24,0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                VerticalAlignment="Center"
                Padding="4"
                Background="#1A120F"
                BorderBrush="{StaticResource BurrowStrokeBrush}"
                BorderThickness="1"
                CornerRadius="30">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button
                        x:Name="UninstallTabButton"
                        Click="AppsTabButton_Click"
                        Content="Uninstall"
                        Style="{StaticResource BurrowTopNavButtonSelectedStyle}"
                        Tag="uninstall" />
                    <Button
                        x:Name="UpdatesTabButton"
                        Click="AppsTabButton_Click"
                        Content="Updates"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="updates" />
                    <Button
                        x:Name="StartupTabButton"
                        Click="AppsTabButton_Click"
                        Content="Startup"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="startup" />
                </StackPanel>
            </Border>

            <Grid
                Grid.Column="1"
                Width="456"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="NameSortButton"
                    HorizontalAlignment="Stretch"
                    MinWidth="112"
                    Command="{Binding SortCommand}"
                    CommandParameter="name"
                    Content="name"
                    Style="{StaticResource BurrowTopNavButtonStyle}" />
                <Button
                    x:Name="SizeSortButton"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    MinWidth="112"
                    Command="{Binding SortCommand}"
                    CommandParameter="size"
                    Content="size"
                    Style="{StaticResource BurrowTopNavButtonSelectedStyle}" />
                <Button
                    x:Name="SourceSortButton"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    MinWidth="112"
                    Command="{Binding SortCommand}"
                    CommandParameter="source"
                    Content="source"
                    Style="{StaticResource BurrowTopNavButtonStyle}" />
                <Button
                    Grid.Column="3"
                    Command="{Binding LoadCommand}"
                    Content="&#xE72C;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource BurrowIconButtonStyle}" />
            </Grid>

            <TextBox
                Grid.Column="2"
                VerticalAlignment="Center"
                PlaceholderText="Search apps"
                Style="{StaticResource AppsSearchBoxStyle}"
                Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource BurrowStrokeBrush}" BorderThickness="0,1,0,1">
            <Grid>
                <Grid x:Name="UninstallContent">
                    <ListView
                        Padding="24,16,24,0"
                        ItemContainerStyle="{StaticResource AppsListViewItemStyle}"
                        ItemsSource="{Binding Applications}"
                        SelectedItem="{Binding SelectedApplicationRow, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ApplicationRowViewModel">
                                <Grid RowSpacing="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid MinHeight="88" Padding="0,8,18,8" ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowDimBrush}"
                                            Text="{x:Bind ChevronText, Mode=OneWay}" />

                                        <Border
                                            Grid.Column="1"
                                            Width="44"
                                            Height="44"
                                            VerticalAlignment="Center"
                                            Background="#263646"
                                            CornerRadius="9">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource BurrowTextBrush}"
                                                Text="{x:Bind Initials}" />
                                        </Border>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="22"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource BurrowTextBrush}"
                                                Text="{x:Bind Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontFamily="{StaticResource BurrowMonoFont}"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource BurrowDimBrush}"
                                                Text="{x:Bind DetailLine}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowMutedBrush}"
                                            Text="{x:Bind RightSummary}" />

                                        <Ellipse
                                            Grid.Column="4"
                                            Width="31"
                                            Height="31"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Stroke="{StaticResource BurrowDimBrush}"
                                            StrokeThickness="2.5" />
                                    </Grid>

                                    <Border
                                        Grid.Row="1"
                                        Margin="54,0,20,20"
                                        Padding="22"
                                        Background="#151110"
                                        BorderBrush="{StaticResource BurrowStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Visibility="{x:Bind DetailVisibility, Mode=OneWay}">
                                        <Grid RowSpacing="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="22"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource BurrowTextBrush}"
                                                        Text="{x:Bind Name}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource BurrowMonoFont}"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource BurrowDimBrush}"
                                                        Text="{x:Bind InstallLocation}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource BurrowMonoFont}"
                                                    FontSize="17"
                                                    FontWeight="Bold"
                                                    Foreground="{StaticResource BurrowMutedBrush}"
                                                    Text="{Binding DataContext.LeftoverSelectionText, ElementName=AppsRoot}" />
                                                <Button
                                                    Grid.Column="2"
                                                    Command="{Binding DataContext.SelectAllLeftoversCommand, ElementName=AppsRoot}"
                                                    Content="Select all"
                                                    Foreground="{StaticResource BurrowOrangeBrush}"
                                                    Style="{StaticResource BurrowTopNavButtonStyle}" />
                                            </Grid>

                                            <StackPanel
                                                Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="12">
                                                <Button
                                                    Command="{Binding DataContext.PreviewLeftoversCommand, ElementName=AppsRoot}"
                                                    Content="Preview leftovers"
                                                    Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource BurrowMonoFont}"
                                                    FontWeight="Bold"
                                                    Foreground="{StaticResource BurrowDimBrush}"
                                                    Text="{Binding DataContext.LeftoverSummary, ElementName=AppsRoot}" />
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Row="2"
                                                FontFamily="{StaticResource BurrowMonoFont}"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource BurrowDimBrush}"
                                                Text="AUTO SELECTED" />

                                            <ListView
                                                Grid.Row="3"
                                                MaxHeight="260"
                                                ItemContainerStyle="{StaticResource AppsListViewItemStyle}"
                                                ItemsSource="{Binding DataContext.Leftovers, ElementName=AppsRoot}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:LeftoverCandidate">
                                                        <Grid MinHeight="42" ColumnSpacing="14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42" />
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="36" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                FontSize="17"
                                                                FontWeight="SemiBold"
                                                                Foreground="{StaticResource BurrowMutedBrush}"
                                                                Text="{x:Bind Category}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <TextBlock
                                                                Grid.Column="2"
                                                                VerticalAlignment="Center"
                                                                FontFamily="{StaticResource BurrowMonoFont}"
                                                                FontWeight="Bold"
                                                                Foreground="{StaticResource BurrowDimBrush}"
                                                                Text="{x:Bind SizeText}" />
                                                            <TextBlock
                                                                Grid.Column="3"
                                                                VerticalAlignment="Center"
                                                                FontFamily="{StaticResource BurrowMonoFont}"
                                                                FontWeight="Bold"
                                                                Foreground="{StaticResource BurrowDimBrush}"
                                                                Text="{x:Bind Path}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <FontIcon
                                                                Grid.Column="4"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="16"
                                                                Foreground="{StaticResource BurrowDimBrush}"
                                                                Glyph="&#xE721;" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>

                                    <Border
                                        Height="1"
                                        Margin="98,0,18,0"
                                        VerticalAlignment="Bottom"
                                        Background="#332622" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid x:Name="UpdatesContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="118" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="24,0" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource BurrowMonoFont}"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource BurrowMutedBrush}"
                            Text="0 updates" />
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">
                            <ProgressRing
                                Width="26"
                                Height="26"
                                IsActive="{Binding IsBusy}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="Checking..." />
                        </StackPanel>
                        <Button
                            Grid.Column="2"
                            Click="UnsupportedAppsFeatureButton_Click"
                            Content="Check for updates"
                            Style="{StaticResource BurrowPillButtonStyle}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Padding="36,28,36,36" Spacing="26">
                            <TextBlock
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="APPS WITH AN UPDATE MECHANISM 0" />
                            <Border
                                Padding="24"
                                Background="#14100E"
                                BorderBrush="{StaticResource BurrowStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="28"
                                        Foreground="{StaticResource BurrowOrangeBrush}"
                                        Glyph="&#xE895;" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock
                                            FontSize="22"
                                            FontWeight="SemiBold"
                                            Text="Mole Windows updates" />
                                        <TextBlock
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowDimBrush}"
                                            Text="{Binding UpdatesSummary}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource AppsSmallPillStyle}">
                                        <TextBlock
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowOrangeBrush}"
                                            Text="Preview" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="StartupContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="118" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="24,0">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource BurrowMonoFont}"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource BurrowMutedBrush}"
                            Text="Startup inventory" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Padding="36,28,36,36" Spacing="26">
                            <TextBlock
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="WINDOWS STARTUP ITEMS 0" />
                            <Border
                                Padding="24"
                                Background="#14100E"
                                BorderBrush="{StaticResource BurrowStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="28"
                                        Foreground="{StaticResource BurrowGoldBrush}"
                                        Glyph="&#xE7C1;" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock
                                            FontSize="22"
                                            FontWeight="SemiBold"
                                            Text="Startup management" />
                                        <TextBlock
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowDimBrush}"
                                            Text="{Binding StartupSummary}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource AppsSmallPillStyle}">
                                        <TextBlock
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource BurrowGoldBrush}"
                                            Text="Pending" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Padding="24,0" Background="#100E0D">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource BurrowMonoFont}"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{StaticResource BurrowMutedBrush}"
                Text="{Binding AppsCountText}" />
            <Button
                Grid.Column="1"
                Margin="0,0,12,0"
                Click="RemoveLeftoversButton_Click"
                Content="Remove leftovers"
                IsEnabled="{Binding CanRemoveSelectedLeftovers}"
                Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
            <Button
                Grid.Column="2"
                Click="UninstallButton_Click"
                Content="Uninstall"
                IsEnabled="{Binding CanLaunchUninstaller}"
                Style="{StaticResource BurrowPillButtonStyle}" />
        </Grid>
    </Grid>
</Page>
