<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Pages.PurgePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:BurrowWin.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource BurrowBackgroundGreenBrush}"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
            <RowDefinition Height="78" />
        </Grid.RowDefinitions>

        <Grid Padding="24,0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="18">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Purge" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding Summary}" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    Command="{Binding CheckMoleCommand}"
                    Style="{StaticResource BurrowIconButtonStyle}">
                    <FontIcon Glyph="&#xE946;" />
                </Button>
                <Button
                    Command="{Binding PreviewCommand}"
                    Content="Rescan"
                    Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" BorderBrush="{StaticResource BurrowStrokeBrush}" BorderThickness="0,1,0,1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="112" />
            </Grid.RowDefinitions>

            <ListView
                Padding="24,0"
                ItemsSource="{Binding Projects}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PurgeProjectCandidate">
                        <Grid MinHeight="94" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="28"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Glyph="&#xE8B7;" />
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="4">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    FontSize="14"
                                    Foreground="{StaticResource BurrowDimBrush}"
                                    Text="{x:Bind Path}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    FontSize="14"
                                    Foreground="{StaticResource BurrowMutedBrush}"
                                    Text="{x:Bind ArtifactSummary}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Spacing="4">
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource BurrowGoldBrush}"
                                    Text="{x:Bind TotalSizeText}" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontFamily="{StaticResource BurrowMonoFont}"
                                    FontSize="14"
                                    Foreground="{StaticResource BurrowDimBrush}"
                                    Text="{x:Bind ArtifactCount}" />
                            </StackPanel>
                            <CheckBox
                                Grid.Column="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid
                Grid.Row="1"
                Padding="24,12"
                BorderBrush="{StaticResource BurrowStrokeBrush}"
                BorderThickness="0,1,0,0"
                ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="6">
                    <TextBlock
                        FontFamily="{StaticResource BurrowMonoFont}"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource BurrowMutedBrush}"
                        Text="{Binding SelectedSummary}" />
                    <TextBlock
                        FontFamily="{StaticResource BurrowMonoFont}"
                        FontSize="12"
                        Foreground="{StaticResource BurrowDimBrush}"
                        Text="{Binding EngineSummary}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBox
                    Grid.Column="1"
                    Width="420"
                    Height="78"
                    AcceptsReturn="True"
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="12"
                    IsReadOnly="True"
                    Text="{Binding OutputText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Padding="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                <ProgressRing
                    Width="22"
                    Height="22"
                    IsActive="{Binding IsBusy}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{StaticResource BurrowMutedBrush}"
                    Text="project artifacts" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Margin="0,0,12,0"
                Command="{Binding ClearSelectionCommand}"
                Content="clear"
                Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
            <Button
                Grid.Column="2"
                Margin="0,0,12,0"
                Command="{Binding SelectAllCommand}"
                Content="select all"
                Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
            <Button
                Grid.Column="3"
                Margin="0,0,12,0"
                Command="{Binding PreviewCommand}"
                Content="Preview"
                Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
            <Button
                Grid.Column="4"
                Click="RemoveButton_Click"
                Content="Remove"
                IsEnabled="{Binding CanRemove}"
                Style="{StaticResource BurrowPillButtonStyle}" />
        </Grid>
    </Grid>
</Page>
