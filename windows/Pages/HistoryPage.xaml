<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Pages.HistoryPage"
    x:Name="HistoryRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:BurrowWin.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource BurrowBackgroundBrush}"
    Loaded="HistoryPage_Loaded"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="24,0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="History" />
            <Border
                Grid.Column="1"
                Padding="8"
                VerticalAlignment="Center"
                Background="#11110F"
                BorderBrush="{StaticResource BurrowStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button
                        x:Name="Range5mButton"
                        Click="RangeButton_Click"
                        Content="5m"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="5m" />
                    <Button
                        x:Name="Range1hButton"
                        Click="RangeButton_Click"
                        Content="1h"
                        Style="{StaticResource BurrowTopNavButtonSelectedStyle}"
                        Tag="1h" />
                    <Button
                        x:Name="Range6hButton"
                        Click="RangeButton_Click"
                        Content="6h"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="6h" />
                    <Button
                        x:Name="Range24hButton"
                        Click="RangeButton_Click"
                        Content="24h"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="24h" />
                    <Button
                        x:Name="Range7dButton"
                        Click="RangeButton_Click"
                        Content="7d"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="7d" />
                    <Button
                        x:Name="Range30dButton"
                        Click="RangeButton_Click"
                        Content="30d"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="30d" />
                    <Button
                        x:Name="Range90dButton"
                        Click="RangeButton_Click"
                        Content="90d"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="90d" />
                </StackPanel>
            </Border>
            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <TextBlock
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding Summary}" />
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource BurrowIconButtonStyle}">
                    <FontIcon Glyph="&#xE72C;" />
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="24" ColumnSpacing="20" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="320" />
                    <RowDefinition Height="320" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource BurrowCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource BurrowGreenBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="CPU USAGE %" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="14"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="{Binding CpuUsageChart.AverageText}" />
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="1" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="2" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="3" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Viewbox Grid.RowSpan="4" Stretch="Fill">
                                <Canvas Width="100" Height="100">
                                    <Polyline
                                        Points="{Binding CpuUsageChart.Points}"
                                        Stroke="{StaticResource BurrowGreenBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="3" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <TextBlock Grid.Row="2" Style="{StaticResource BurrowMetricTextStyle}" Text="{Binding CpuUsageChart.LatestText}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource BurrowCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource BurrowGoldBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="MEMORY % USED" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="14"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="{Binding MemoryChart.AverageText}" />
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="1" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="2" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="3" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Viewbox Grid.RowSpan="4" Stretch="Fill">
                                <Canvas Width="100" Height="100">
                                    <Polyline
                                        Points="{Binding MemoryChart.Points}"
                                        Stroke="{StaticResource BurrowGoldBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="3" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <TextBlock Grid.Row="2" Style="{StaticResource BurrowMetricTextStyle}" Text="{Binding MemoryChart.LatestText}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource BurrowCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource BurrowBlueBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="DISK % USED" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="14"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="{Binding DiskChart.AverageText}" />
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="1" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="2" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="3" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Viewbox Grid.RowSpan="4" Stretch="Fill">
                                <Canvas Width="100" Height="100">
                                    <Polyline
                                        Points="{Binding DiskChart.Points}"
                                        Stroke="{StaticResource BurrowBlueBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="3" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <TextBlock Grid.Row="2" Style="{StaticResource BurrowMetricTextStyle}" Text="{Binding DiskChart.LatestText}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource BurrowCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource BurrowPurpleBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="NETWORK /S" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="14"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="{Binding NetworkChart.AverageText}" />
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="1" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="2" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Border Grid.Row="3" BorderBrush="#2A2A27" BorderThickness="0,0,0,1" />
                            <Viewbox Grid.RowSpan="4" Stretch="Fill">
                                <Canvas Width="100" Height="100">
                                    <Polyline
                                        Points="{Binding NetworkChart.Points}"
                                        Stroke="{StaticResource BurrowPurpleBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="3" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <TextBlock Grid.Row="2" Style="{StaticResource BurrowMetricTextStyle}" Text="{Binding NetworkChart.LatestText}" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource BurrowCardBorderStyle}">
                    <Grid RowSpacing="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="280" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Foreground="{StaticResource BurrowOrangeBrush}"
                                Style="{StaticResource BurrowLabelTextStyle}"
                                Text="TOP CPU PROCESSES" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                FontSize="14"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="peak / avg / memory" />
                        </Grid>
                        <TextBlock
                            Grid.Row="1"
                            FontFamily="{StaticResource BurrowMonoFont}"
                            Foreground="{StaticResource BurrowDimBrush}"
                            Text="{Binding HistoryPath}"
                            TextWrapping="Wrap" />
                        <ListView
                            Grid.Row="2"
                            ItemsSource="{Binding CpuProcessLeaders}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProcessUsageSummary">
                                    <Grid MinHeight="44" ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="130" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            Foreground="{StaticResource BurrowDimBrush}"
                                            Text="{x:Bind ProcessId}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            Foreground="{StaticResource BurrowOrangeBrush}"
                                            Text="{x:Bind PeakCpuUsageText}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            Foreground="{StaticResource BurrowMutedBrush}"
                                            Text="{x:Bind AverageCpuUsageText}" />
                                        <TextBlock
                                            Grid.Column="4"
                                            FontFamily="{StaticResource BurrowMonoFont}"
                                            Foreground="{StaticResource BurrowMutedBrush}"
                                            Text="{x:Bind PeakWorkingSetText}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
