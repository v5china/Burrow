<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:BurrowWin.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource BurrowBackgroundGreenBrush}"
    Loaded="CleanupPage_Loaded"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid MinHeight="760" Padding="24,28,24,24" RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="480" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="24">
                <Border
                    Width="220"
                    Height="220"
                    CornerRadius="110">
                    <Border.Background>
                        <RadialGradientBrush Center="0.35,0.3" RadiusX="0.85" RadiusY="0.85">
                            <GradientStop Color="#66C7A7" Offset="0" />
                            <GradientStop Color="#3A6C5D" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource BurrowSerifFont}"
                        FontSize="42"
                        FontWeight="SemiBold"
                        Text="Clean" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource BurrowSerifFont}"
                        FontSize="20"
                        FontStyle="Italic"
                        Foreground="{StaticResource BurrowMutedBrush}"
                        Text="Fresh air through old tunnels." />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource BurrowMonoFont}"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource BurrowGoldBrush}"
                        Text="{Binding PendingMessage}" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="16">
                    <Button
                        Click="CleanButton_Click"
                        Content="Clean Now"
                        IsEnabled="{Binding CanClean}"
                        Style="{StaticResource BurrowPillButtonStyle}" />
                    <Button
                        Command="{Binding ScanCommand}"
                        Content="Preview"
                        IsEnabled="{Binding CanPreview}"
                        Style="{StaticResource BurrowSecondaryPillButtonStyle}" />
                    <ProgressRing
                        Width="28"
                        Height="28"
                        IsActive="{Binding IsBusy}" />
                </StackPanel>

                <TextBlock
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource BurrowMonoFont}"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding Summary}" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource BurrowCardBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="280" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="{StaticResource BurrowGreenBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="PREVIEW ITEMS" />
                    <ListView Grid.Row="1" ItemsSource="{Binding PreviewItems}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CleanupPreviewItem">
                                <Grid MinHeight="52" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Category}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" FontFamily="{StaticResource BurrowMonoFont}" Foreground="{StaticResource BurrowMutedBrush}" Text="{x:Bind SizeText}" />
                                    <TextBlock Grid.Column="2" FontFamily="{StaticResource BurrowMonoFont}" Foreground="{StaticResource BurrowDimBrush}" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <TextBox
                Grid.Row="2"
                AcceptsReturn="True"
                FontFamily="{StaticResource BurrowMonoFont}"
                IsReadOnly="True"
                Text="{Binding OutputText, Mode=OneWay}"
                TextWrapping="Wrap" />
        </Grid>
    </ScrollViewer>
</Page>
