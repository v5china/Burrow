<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BurrowWin.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#17130D"
    Loaded="ShellPage_Loaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="172" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="AppTitleBar" Background="Transparent" />

        <Grid
            Padding="0,78,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BrandButton"
                Width="70"
                Height="70"
                Padding="0"
                Click="TopNav_Click"
                Style="{StaticResource BurrowIconButtonSelectedStyle}"
                Tag="status">
                <Grid>
                    <Ellipse Stroke="#3D3A34" StrokeThickness="2" />
                    <Ellipse
                        Margin="8"
                        Stroke="#77736A"
                        StrokeThickness="4" />
                    <Ellipse
                        Width="48"
                        Height="48"
                        Fill="{StaticResource BurrowWhitePillBrush}" />
                    <Path
                        Width="32"
                        Height="16"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M0,16 C1.4,5.4 7.8,0 16,0 C24.2,0 30.6,5.4 32,16 L32,20 L0,20 Z"
                        Fill="Black"
                        Stretch="Fill" />
                </Grid>
            </Button>

            <Border
                Grid.Column="1"
                Width="798"
                Padding="22,10"
                Background="#15130F"
                BorderBrush="#332F29"
                BorderThickness="2"
                CornerRadius="34">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="CleanNavButton"
                        HorizontalAlignment="Stretch"
                        Click="TopNav_Click"
                        Content="clean"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="clean" />
                    <Button
                        x:Name="OptimizeNavButton"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Click="TopNav_Click"
                        Content="optimize"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="optimize" />
                    <Button
                        x:Name="AppsNavButton"
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Click="TopNav_Click"
                        Content="apps"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="apps" />
                    <Button
                        x:Name="AnalyzeNavButton"
                        Grid.Column="3"
                        HorizontalAlignment="Stretch"
                        Click="TopNav_Click"
                        Content="analyze"
                        Style="{StaticResource BurrowTopNavButtonStyle}"
                        Tag="analyze" />
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Width="70"
                Height="70"
                Background="#15130F"
                BorderBrush="#332F29"
                BorderThickness="2"
                CornerRadius="35">
                <Button
                    x:Name="SettingsButton"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="TopNav_Click"
                    Style="{StaticResource BurrowIconButtonStyle}"
                    Tag="settings">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        Glyph="&#xE713;" />
                </Button>
            </Border>
        </Grid>

        <Frame
            x:Name="ContentFrame"
            Grid.Row="1"
            Navigated="ContentFrame_Navigated" />
    </Grid>
</Page>
