<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="BurrowWin.Views.TrayHudWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Burrow HUD"
    mc:Ignorable="d">

    <Grid
        x:Name="HudRoot"
        Width="430"
        MinHeight="860"
        Padding="18"
        Background="#26312D"
        RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="HudTitleBar" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Ellipse
                Width="34"
                Height="34"
                Fill="{StaticResource BurrowWhitePillBrush}" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Burrow" />
                <TextBlock
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="12"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding SampleText}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource BurrowCardBorderStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock
                        Foreground="{StaticResource BurrowGoldBrush}"
                        Style="{StaticResource BurrowLabelTextStyle}"
                        Text="HEALTH" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock
                            FontSize="42"
                            FontWeight="SemiBold"
                            Text="{Binding HealthScore}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BurrowGreenBrush}"
                            Text="{Binding HealthLabel}" />
                    </StackPanel>
                </StackPanel>
                <Border
                    Grid.Column="1"
                    Width="86"
                    Height="86"
                    BorderBrush="{StaticResource BurrowGreenBrush}"
                    BorderThickness="9"
                    CornerRadius="43">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="{Binding HealthScore}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="14" Style="{StaticResource BurrowCardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="{StaticResource BurrowGreenBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="CPU" />
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding CpuText}" />
                </StackPanel>
            </Border>
            <Border
                Grid.Column="1"
                Padding="14"
                Style="{StaticResource BurrowCardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="{StaticResource BurrowGoldBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="MEMORY" />
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding MemoryText}" />
                </StackPanel>
            </Border>
            <Border
                Grid.Row="1"
                Padding="14"
                Style="{StaticResource BurrowCardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="{StaticResource BurrowRedBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="DISK" />
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding DiskText}" />
                </StackPanel>
            </Border>
            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="14"
                Style="{StaticResource BurrowCardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="{StaticResource BurrowBlueBrush}" Style="{StaticResource BurrowLabelTextStyle}" Text="NETWORK" />
                    <TextBlock
                        FontFamily="{StaticResource BurrowMonoFont}"
                        FontSize="13"
                        Text="{Binding NetworkText}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource BurrowCardBorderStyle}">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Foreground="{StaticResource BurrowGoldBrush}"
                        Style="{StaticResource BurrowLabelTextStyle}"
                        Text="ACTIVITY" />
                    <Button
                        Grid.Column="1"
                        Click="NavigationButton_Click"
                        Content="Activity"
                        Style="{StaticResource BurrowSecondaryPillButtonStyle}"
                        Tag="activity" />
                </Grid>
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{Binding ActivityTitle}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    FontFamily="{StaticResource BurrowMonoFont}"
                    FontSize="12"
                    Foreground="{StaticResource BurrowDimBrush}"
                    Text="{Binding ActivityDetail}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Foreground="{StaticResource BurrowMutedBrush}"
                Style="{StaticResource BurrowLabelTextStyle}"
                Text="TOP PROCESSES" />
            <ListView
                Grid.Row="1"
                MaxHeight="150"
                ItemsSource="{Binding TopProcesses}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="30" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource BurrowTextBrush}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                Foreground="{StaticResource BurrowOrangeBrush}"
                                Text="{Binding CpuUsageText}" />
                            <TextBlock
                                Grid.Column="2"
                                FontFamily="{StaticResource BurrowMonoFont}"
                                Foreground="{StaticResource BurrowDimBrush}"
                                Text="{Binding WorkingSetText}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="2" ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Button Click="NavigationButton_Click" Content="Status" Style="{StaticResource BurrowPillButtonStyle}" Tag="status" />
                <Button Grid.Column="1" Click="NavigationButton_Click" Content="Clean" Style="{StaticResource BurrowSecondaryPillButtonStyle}" Tag="clean" />
                <Button Grid.Column="2" Click="NavigationButton_Click" Content="Optimize" Style="{StaticResource BurrowSecondaryPillButtonStyle}" Tag="optimize" />
                <Button Grid.Row="1" Click="NavigationButton_Click" Content="History" Style="{StaticResource BurrowSecondaryPillButtonStyle}" Tag="history" />
                <Button Grid.Row="1" Grid.Column="1" Click="NavigationButton_Click" Content="Activity" Style="{StaticResource BurrowSecondaryPillButtonStyle}" Tag="activity" />
                <Button Grid.Row="1" Grid.Column="2" Click="NavigationButton_Click" Content="Settings" Style="{StaticResource BurrowSecondaryPillButtonStyle}" Tag="settings" />
            </Grid>
        </Grid>
    </Grid>
</Window>
