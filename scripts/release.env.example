# Copy to scripts/release.env (gitignored) and fill in to ship telemetry in a
# Release build. Leave a value empty to disable that SDK. release.sh sources
# this and passes the values to xcodebuild as build settings, which expand into
# Info.plist (PHPostHogApiKey / PHPostHogHost / SentryDSN).

# PostHog project API key (the public "phc_..." client key — safe to ship).
POSTHOG_API_KEY=

# Optional. Defaults to https://us.i.posthog.com. Use https://eu.i.posthog.com
# for EU data residency.
#POSTHOG_HOST=https://us.i.posthog.com

# Sentry DSN for crash/error reporting.
SENTRY_DSN=
