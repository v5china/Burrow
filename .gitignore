# Generated by xcodegen — re-run `xcodegen generate` to recreate.
Burrow.xcodeproj/
*.xcworkspace/

# Visual Studio / .NET / WinUI
.vs/
.vscode/
bin/
obj/
artifacts/
TestResults/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Windows packaging and publish outputs
publish/
*.appx
*.appxbundle
*.msix
*.msixbundle
*.msixupload

# Xcode build artifacts
build/
build_dist/
dist/
DerivedData/
*.swiftpm/

# macOS junk
.DS_Store

# Agent worktrees and session state
.claude/

# Local-only files
*.xcuserstate
xcuserdata/

# LLVM coverage from `xcodebuild test`
*.profraw
*.profdata
build_test/

# Telemetry secrets (never commit)
scripts/release.env

# local build output (this session's DerivedData)
build_dd/

# Vendored Sentry framework — fetched by scripts/fetch-sentry.sh, not committed.
# Sentry is a local framework, not an SPM package (SPM's binary-artifact
# download hangs xcodebuild on CI; see that script).
macos/vendor/Sentry.xcframework/
macos/vendor/.sentry-*.ok
